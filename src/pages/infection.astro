---
import Layout from '../layouts/Layout.astro';
import Contact from '../components/Contact.astro';
---

<Layout title="特設ページ：感染症対策 | 株式会社新二ホンテック">
    <main class="pt-32 pb-20 bg-light min-h-screen">
        <div class="section-container max-w-4xl">
            
            <!-- パンくずリスト -->
            <nav class="breadcrumb">
                <a href="/">トップ</a>
                <span>感染症対策</span>
            </nav>

            <div class="section-header mb-12 md:mb-20">
                <span class="section-eyebrow">Infection Control</span>
                <h1 class="section-title tracking-wider">感染症対策</h1>
                <div class="section-divider"></div>
            </div>

            <div class="space-y-12 md:space-y-16">
                
                <!-- 01 指先消毒・除菌 -->
                <section class="card--detail p-6 md:p-10 shadow-md hover:shadow-xl hover:-translate-y-1 transition duration-300 text-left">
                    <div class="flex items-start gap-4 md:gap-6 mb-8 md:mb-10">
                        <div class="icon-circle--surface">
                            <i class="fas fa-hands-wash"></i>
                        </div>
                        <div>
                            <h3 class="text-xl md:text-2xl font-bold text-primary mb-2">指先消毒、除菌</h3>
                            <p class="text-base text-text-body leading-relaxed">
                                玄関や居室の入口にアルコール消毒液を設置しています。
                            </p>
                        </div>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div class="rounded-lg shadow-sm border border-border overflow-hidden bg-light">
                            <img src="/assets/infection_images/infection1-1.jpg" alt="アルコール消毒液の設置場所（入口）" class="w-full h-64 object-cover" />
                        </div>
                        <div class="rounded-lg shadow-sm border border-border overflow-hidden bg-light">
                            <img src="/assets/infection_images/infection1-2.jpg" alt="アルコール消毒液の設置場所（玄関）" class="w-full h-64 object-cover" />
                        </div>
                    </div>
                </section>

                <!-- 02 空間除菌 -->
                <section class="card--detail p-6 md:p-10 shadow-md hover:shadow-xl hover:-translate-y-1 transition duration-300 text-left">
                    <div class="flex items-start gap-4 md:gap-6 mb-8 md:mb-10">
                        <div class="icon-circle--surface">
                            <i class="fas fa-wind"></i>
                        </div>
                        <div>
                            <h3 class="text-xl md:text-2xl font-bold text-primary mb-2">空間除菌</h3>
                            <p class="text-base text-text-body leading-relaxed">
                                各居室に次亜塩素酸 空間除菌脱臭機を設置しています。
                            </p>
                        </div>
                    </div>
                    <div class="w-full sm:w-1/2 mx-auto rounded-lg shadow-sm border border-border overflow-hidden bg-light">
                        <img src="/assets/infection_images/infection2.jpg" alt="次亜塩素酸 空間除菌脱臭機" class="w-full h-64 object-cover" />
                    </div>
                </section>

                <!-- 03 飛沫対策 -->
                <section class="card--detail p-6 md:p-10 shadow-md hover:shadow-xl hover:-translate-y-1 transition duration-300 text-left">
                    <div class="flex items-start gap-4 md:gap-6 mb-8 md:mb-10">
                        <div class="icon-circle--surface">
                            <i class="fas fa-people-arrows"></i>
                        </div>
                        <div>
                            <h3 class="text-xl md:text-2xl font-bold text-primary mb-2">飛沫対策</h3>
                            <p class="text-base text-text-body leading-relaxed">
                                個人デスク間を抗菌フィルムで隔離しています。
                            </p>
                        </div>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div class="rounded-lg shadow-sm border border-border overflow-hidden bg-light">
                            <img src="/assets/infection_images/infection3-1.jpg" alt="デスクに設置された抗菌フィルム（全体）" class="w-full h-64 object-cover" />
                        </div>
                        <div class="rounded-lg shadow-sm border border-border overflow-hidden bg-light">
                            <img src="/assets/infection_images/infection3-2.jpg" alt="デスクに設置された抗菌フィルム（接写）" class="w-full h-64 object-cover" />
                        </div>
                    </div>
                </section>
            </div>
            
            <div class="mt-16 md:mt-20 text-center">
                <a href="/" class="btn-back">
                    トップページへ戻る
                </a>
            </div>

        </div>
    </main>

    <Contact />

    <script src="/assets/js/common.js" is:inline></script>

</Layout>