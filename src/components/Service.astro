                        </ul>
                    </div>
                </div>
            </div>

            <!-- 02 基板回路設計・制御盤Assy -->
            <div class="bg-surface text-text-body rounded-xl shadow-2xl overflow-hidden">
                <div class="flex flex-col md:flex-row-reverse md:items-center">
                    <div class="h-64 md:h-auto md:self-stretch md:w-1/2 flex-shrink-0">
                        <img src="/assets/images/service2.jpg" alt="制御盤" class="w-full h-full object-cover">
